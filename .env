# SendGrid Primary
SENDGRID_API_KEY=your_sendgrid_api_key

# 20i SMTP Fallback
MAIL_FALLBACK_HOST=smtp.stackmail.com
MAIL_FALLBACK_PORT=587
MAIL_FALLBACK_USERNAME=your_email@orbit.innovators4u.pk
MAIL_FALLBACK_PASSWORD=your_email_password
MAIL_FALLBACK_ENCRYPTION=tls

# Broadcast - Log (not Reverb/WebSocket)
BROADCAST_CONNECTION=log

# File Storage - Local (not S3 for shared hosting)
FILESYSTEM_DISK=local

# Security
CRON_SECRET=your-secure-random-string-here

# API Keys
STRIPE_KEY=your_stripe_key
STRIPE_SECRET=your_stripe_secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
